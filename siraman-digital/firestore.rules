rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Function: Cek apakah user adalah admin
    function isAdmin() {
      return request.auth != null && request.auth.uid != null;
    }

    // Public Read-Only Collections (Publik bisa baca, Admin bisa tulis/edit)
    match /profile/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /news/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /gallery/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /programs/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /events/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /announcements/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /faq/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Aspirasi Warga (Publik bisa buat/create, Admin bisa baca, edit, hapus)
    match /aspirations/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Collection Users (Hanya Admin terautentikasi yang bisa akses)
    match /users/{userId} {
      allow read, write: if isAdmin() && request.auth.uid == userId;
    }
  }
}
